<Window x:Class="LAB4._1SultanovaED.WindowEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LAB4._1SultanovaED"
        mc:Ignorable="d"
        Title="Сотрудники" Height="350" Width="600">
    <Grid>
        <ListView x:Name="lvEmployee" Margin="10">
            <ListView.View>
                <GridView>
                    <GridView.Columns>
                        <GridViewColumn Header="Код" Width="60" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Фамилия" Width="120" DisplayMemberBinding="{Binding LastName}"/>
                        <GridViewColumn Header="Имя" Width="100" DisplayMemberBinding="{Binding FirstName}"/>
                        <GridViewColumn Header="Должность" Width="150" DisplayMemberBinding="{Binding Role}"/>
                        <GridViewColumn Header="Дата рождения" Width="120" DisplayMemberBinding="{Binding Birthday, StringFormat=dd.MM.yyyy}"/>
                    </GridView.Columns>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>