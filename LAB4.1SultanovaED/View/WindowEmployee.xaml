<Window x:Class="WpfAppSultanovaED.View.WindowEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppSultanovaED"
        mc:Ignorable="d"
        Title="Сотрудники" Height="350" Width="600"
        Background="White">
    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить" Command="{Binding AddPerson}" Margin="0,0,5,0"
                    Background="DarkGray" Foreground="White" Padding="5,2"/>
            <Button Content="Редактировать" Command="{Binding EditPerson}" Margin="0,0,5,0"
                    Background="DarkGray" Foreground="White" Padding="5,2"/>
            <Button Content="Удалить" Command="{Binding DeletePerson}"
                    Background="DarkGray" Foreground="White" Padding="5,2"/>
        </StackPanel>
        <ListView x:Name="lvEmployee" Grid.Row="1" ItemsSource="{Binding ListPersonDpo}"
                  SelectedItem="{Binding SelectedPersonDpo, Mode=TwoWay}"
                  Background="White" BorderBrush="Black" BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridView.Columns>
                        <GridViewColumn Header="Код" Width="60" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Фамилия" Width="120" DisplayMemberBinding="{Binding LastName}"/>
                        <GridViewColumn Header="Имя" Width="100" DisplayMemberBinding="{Binding FirstName}"/>
                        <GridViewColumn Header="Должность" Width="150" DisplayMemberBinding="{Binding RoleName}"/>
                        <GridViewColumn Header="Дата рождения" Width="120" DisplayMemberBinding="{Binding Birthday, StringFormat=dd.MM.yyyy}"/>
                    </GridView.Columns>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>