<Window x:Class="WpfAppSultanovaED.View.WindowNewEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppSultanovaED.View"
        mc:Ignorable="d"
        Title="Добавление нового сотрудника" Height="350" Width="400"
        Background="White">

    <Window.Resources>
        <Style x:Key="TextBoxDate" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Visibility" Value="Hidden" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0">Фамилия:</Label>
        <TextBox Grid.Row="0" Grid.Column="1" Name="TbLastName" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="TbLastName_PreviewTextInput"/>

        <Label Grid.Row="1" Grid.Column="0">Имя:</Label>
        <TextBox Grid.Row="1" Grid.Column="1" Name="TbFirstName" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="TbFirstName_PreviewTextInput"/>

        <Label Grid.Row="2" Grid.Column="0">Должность:</Label>
        <ComboBox Grid.Row="2" Grid.Column="1" Name="CbRole" DisplayMemberPath="NameRole" SelectedValuePath="NameRole" SelectedValue="{Binding RoleName, UpdateSourceTrigger=PropertyChanged}"/>

        <Label Grid.Row="3" Grid.Column="0">Дата рождения:</Label>
        <TextBox x:Name="tbBirthday"
                 Grid.Row="3" Grid.Column="1"
                 Width="130" Height="20"
                 Margin="5,8,0,7"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 Style="{StaticResource TextBoxDate}"
                 Text="{Binding Birthday, StringFormat={}{0:dd.MM.yyyy}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 IsVisibleChanged="tbBirthday_IsVisibleChanged" />
        <DatePicker x:Name="ClBirthday"
                    Grid.Row="3" Grid.Column="1"
                    Width="130"
                    Margin="5,8,0,7"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Visibility="Hidden"
                    SelectedDate="{Binding Birthday, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                Name="BtSave" Content="Сохранить" Click="BtSave_Click"
                Background="DarkGray" Foreground="White" Padding="5,2"/>
    </Grid>
</Window>